---
import GoogleIcon from "./GoogleIcon";
import RoverIcon from "./RoverIcon";
import YelpIcon from "./YelpIcon";

const REVIEWS = [
  {
    name: "Judy Mao",
    text: "Brenton has been the provider of our doggy daycare needs for almost a month now. I don't know what his secret is, but I see a change in Mia. She used to be reactive when I drop her off, barking in the car and super excited, but since going to his backyard almost every work day, she comes home calm and doesn't even jump as much as before. Not only are his prices reasonable, he has deals for monthly plans. Brenton is very flexible with drop off and pick up times and works with me on my schedule and budget. I can't recommend him enough",
    link: "https://share.google/5CDicTQS8RdbP8ilV",
  },
  {
    name: "Gina HazElmore",
    text: "I was so nervous leaving my dogs for my first vacation away from them, but Brenton exceeded all my expectations. He turned a stressful situation into a completely worry free one. His commitment to keeping me informed with daily video and photo updates was incredibly reassuring and a huge relief. His care and communication were outstanding, and I wouldn't hesitate to book him again.",
    link: "https://share.google/jiOrPid7IYquszsub"
  },
  {
    name: "Janelle Bowerman",
    text: "Brenton is super experienced with dogs and provides excellent care. Our dog, Levon, has stayed with Brenton twice now, and he has become our go to dog sitter when we're away. It gives us peace of mind knowing Levon is receiving high quality care, training and socialization while we're away. We also appreciate all of his Instagram updates/photos! Highly recommend!",
    link: "https://share.google/rHEiUjr8jwhFClHzr"
  },
  {
    name: "Justine Javier",
    text: "My Frenchie Minnie loves her stays at Brenton's Barkyard! It is always a 10/10. Brenton is very attentive when caring for Minnie and gives her so much love while I am away and out of town. Brenton usually has multiple dogs there at one time and Minnie absolutely loves it because she can play all day everyday. Brenton also updates me daily whether it's through text or Instagram which really puts my mind at ease because I'm always worrying when I have to leave Minnie behind. Thank you for always taking such good care of my Minnie! She can't wait for her next stay at the Barkyard! 😁",
    link: 'https://share.google/0Uag3LZFIFUfoWVcE'
  },
];
---

<section id="reviews" class="section banner is-flex is-flex-direction-column">
  <h1 class="title main-title is-flex is-justify-content-center">
    <span class="mr-3 section-header">Reviews</span>
  </h1>

  <div class="carousel-wrapper container">
    <div class="carousel" id="reviews-carousel">
      {REVIEWS.map((review, i) => (
        <div class={`carousel-slide${i === 0 ? ' active' : ''}`} data-index={i}>
          <div class="section-content review-card">
            <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="review-text">"{review.text}"</p>
            <p class="reviewer-name">— {review.name}</p>
            <a href={review.link} target="_blank" rel="noopener" class="review-link">
              <GoogleIcon width="14" height="14" />
              Read on Google
            </a>
          </div>
        </div>
      ))}
      <div class="carousel-slide">
        <div class="section-content review-card cta-card">
          <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="cta-heading">Check out the rest of my reviews!</p>
          <div class="cta-buttons">
            <a href="https://share.google/ceLf7vjRbfEqdyyKC" target="_blank" rel="noopener" class="review-link review-link--large blue">
              <GoogleIcon width="18" height="18" />
              Google
            </a>
            <a href="https://www.rover.com/members/brenton-y-spacious-yard-in-downtown-millbrae/" target="_blank" rel="noopener" class="review-link review-link--large rover-link">
              <RoverIcon width="18" height="18" />
              Rover
            </a>
            <a href="https://www.yelp.com/biz/brenton-s-barkyard-millbrae#reviews" target="_blank" rel="noopener" class="review-link review-link--large yelp-link">
              <YelpIcon width="18" height="18" />
              Yelp
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="carousel-controls">
      <button class="carousel-btn" id="prev-btn" aria-label="Previous review">&#8592;</button>
      <div class="carousel-dots">
        {REVIEWS.map((_, i) => (
          <button class={`dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Review ${i + 1}`}></button>
        ))}
        <button class="dot" data-dot={REVIEWS.length} aria-label={`Review ${REVIEWS.length + 1}`}></button>
      </div>
      <button class="carousel-btn" id="next-btn" aria-label="Next review">&#8594;</button>
    </div>
  </div>
</section>

<style>
  .banner {
    background: #f5f0e8;
    gap: 2rem;
  }

  .carousel-wrapper {
    position: relative;
    overflow: hidden;
  }

  .carousel {
    display: flex;
    transition: transform 0.4s ease;
  }

  .carousel-slide {
    min-width: 100%;
    box-sizing: border-box;
    padding: 0 1rem;
  }

  .review-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    max-width: 680px;
    margin: 0 auto;
  }

  .stars {
    color: #edb067;
    font-size: 1.75rem;
    letter-spacing: 4px;
  }

  .review-text {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #e0e0e0;
    font-style: italic;
  }

  .reviewer-name {
    font-family: "Montserrat", sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 1px;
    color: #edb067;
    text-transform: uppercase;
  }

  .carousel-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .carousel-btn {
    background: #353535;
    color: white;
    border: none;
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.1rem;
    cursor: pointer;
    transition: background 0.2s;

    &:hover {
      background: #edb067;
      color: #353535;
    }
  }

  .carousel-dots {
    display: flex;
    gap: 0.6rem;
  }

  .cta-card {
    justify-content: center;
    padding: 2.5rem 2rem;
  }

  .cta-heading {
    font-family: "Montserrat", sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    color: white;
    letter-spacing: 0.5px;
    margin: 0;
  }

  .cta-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: #c8c8c8;
    margin: 0;
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .review-link--large {
    font-size: 0.95rem;
    padding: 0.65rem 1.5rem;
    margin-top: 0.5rem;
  }

  .review-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #ba7304;
    color: white;
    font-family: "Montserrat", sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    padding: .5rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.2s;

    &:hover {
      background: #764a03;
    }
  }

  .rover-link {
    background: #00bd68;

    &:hover {
      background: #008a4c;
    }
  }

  .yelp-link {
    background: #FF1A1A;

    &:hover {
      background: #d21616;
    }
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background: #c4b8a8;
    cursor: pointer;
    transition: background 0.2s;

    &.active {
      background: #edb067;
    }
  }

  .blue {
    background: #4285F4;

    &:hover {
      background: #3367D6;
    }
  }
</style>

<script>
  const carousel = document.getElementById('reviews-carousel') as HTMLElement;
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  const total = dots.length;
  let current = 0;

  function goTo(index: number) {
    current = (index + total) % total;
    carousel.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  document.getElementById('prev-btn')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('next-btn')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
</script>
